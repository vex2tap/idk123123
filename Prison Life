------------------------------------------------------------------------
-- AUTOMATED ITEM PICKUP PROCESS LOOP (LAG-FREE VERSION)
------------------------------------------------------------------------
-- Items grabbed by name straight out of Workspace (game:GetService("Workspace")).
local PickupTargets = { "Key card", "M9" }

local pickupDebounce = {}

local function fireGiver(object)
    if not object then return end
    local args = { object }
    giver_remote:FireServer(unpack(args))
end

local function triggerGiver(object)
    if not AutoPickUpEnabled or not object then return end

    local character = local_player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local target_pos = (object:IsA("Model") and object:GetPivot().Position)
        or (object:IsA("BasePart") and object.Position)
    if not target_pos then return end

    if (hrp.Position - target_pos).Magnitude <= PickUpRadius then
        if pickupDebounce[object] and (os.clock() - pickupDebounce[object]) < 1 then return end
        pickupDebounce[object] = os.clock()
        fireGiver(object) -- send the REAL item reference, not a blank Model
    end
end

task.spawn(function()
    while task.wait(0.3) do
        if AutoPickUpEnabled then
            -- Named pickups (Key card, M9, ...) pulled directly from Workspace.
            for _, name in ipairs(PickupTargets) do
                local item = WorkspaceService:FindFirstChild(name)
                if item then triggerGiver(item) end
            end

            -- Generic giver pads / ClickDetector items anywhere in Workspace.
            for _, object in ipairs(WorkspaceService:GetChildren()) do
                if object.Name == "Giver" or object:FindFirstChildOfClass("ClickDetector") then
                    triggerGiver(object)
                end
            end
        end
    end
end)

------------------------------------------------------------------------
-- AIM CORRECTION HOOK FILTER
------------------------------------------------------------------------
local function get_closest_player(part_name, fov)
    fov = fov or math.huge
    local closest_player = nil
    local closest_position = nil
    local closest_distance = fov

    for _, player in players:GetPlayers() do
        if player == local_player or player.Team == local_player.Team then continue end
        if TargetSpecificPlayer ~= "Everyone" and player.Name ~= TargetSpecificPlayer then continue end

        local character = player.Character
        local part = character and character:FindFirstChild(part_name)
        if not part then continue end
        
        local screen_position = camera:WorldToViewportPoint(part.Position)
        if screen_position.Z <= 0 then continue end
        
        local screen_center = user_input_service:GetMouseLocation()
        local screen_distance = (Vector2.new(screen_position.X, screen_position.Y) - screen_center).Magnitude
        
        if screen_distance < closest_distance then
            closest_player = player
            closest_position = part.Position
            closest_distance = screen_distance
        end
    end
    return closest_player, closest_position
end

LPH_NO_UPVALUES = function(Function)
    return function(...) return Function(...) end
end

-- Legacy castRay silent aim. Needs filtergc + hookfunction, which lightweight
-- executors (e.g. Xeno) do not support, so it is wrapped to fail quietly and
-- never block the independent systems below it.
pcall(function()
    local castRay = filtergc("function", {Name = "castRay"}, true)
    local old; old = hookfunction(castRay, LPH_NO_UPVALUES(function(...)
        if SilentAimEnabled then
            if math.random(1, 100) <= HitChanceValue then
                local closest_player, closest_position = get_closest_player(HIT_PART, FOV_Size)
                if closest_player and closest_position and closest_player.Character:FindFirstChild(HIT_PART) then
                    task.spawn(playHitSound)
                    return closest_player.Character[HIT_PART], closest_position
                end
            end
        end
        return old(...)
    end))
end)

------------------------------------------------------------------------
-- GUN-REMOTE SILENT AIM (independent / hook-free)  --  Xeno-safe
------------------------------------------------------------------------
-- No hookmetamethod / hookfunction / getnamecallmethod / newcclosure / filtergc.
-- Fires the gun's own ShootEvent ONE shot per click at the locked FOV target.
-- Per-click pacing (plus a min-gap) avoids the remote-flood that desyncs ammo
-- and trips anti-cheat into locking your tools.
--
--   ShootEvent:FireServer({ { origin, hitPos, hitPart } })
local gun_shoot_event = nil
local gun_last_shot = 0

-- Where the bullet starts: equipped tool's handle, otherwise the camera.
local function getOriginPosition()
    local character = local_player.Character
    local tool = character and character:FindFirstChildOfClass("Tool")
    if tool then
        local handle = tool:FindFirstChild("Handle") or tool:FindFirstChildWhichIsA("BasePart")
        if handle then return handle.Position end
    end
    return camera.CFrame.Position
end

local function trySilentShot()
    if not SilentAimGunEnabled then return end
    if not gun_shoot_event then return end
    if (os.clock() - gun_last_shot) < GunFireDelay then return end
    if math.random(1, 100) > HitChanceValue then return end

    local target_player = get_closest_player(HIT_PART, FOV_Size)
    local target_part = target_player
        and target_player.Character
        and target_player.Character:FindFirstChild(HIT_PART)
    if not target_part then return end

    gun_last_shot = os.clock()
    local args = {
        {
            {
                getOriginPosition(), -- origin
                target_part.Position, -- hit position -> locked body part
                target_part           -- hit instance -> locked body part
            }
        }
    }
    pcall(function() gun_shoot_event:FireServer(unpack(args)) end)
    task.spawn(playHitSound)
end

-- One redirected shot per real left-click (no spam loop).
user_input_service.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        trySilentShot()
    end
end)

-- Resolve the remote off-thread so script load never blocks.
task.spawn(function()
    local gun_remotes = replicated_storage:WaitForChild("GunRemotes", 10)
    gun_shoot_event = (gun_remotes and gun_remotes:WaitForChild("ShootEvent", 10)) or nil
end)

------------------------------------------------------------------------
-- AUTO ARREST (nearest player)  --  Xeno-safe
------------------------------------------------------------------------
-- ArrestPlayer is a RemoteFunction:
--   Remotes.ArrestPlayer:InvokeServer(targetPlayer, 1)
-- The hardcoded "VenusMc253" is swapped for whoever is physically closest to
-- you. Each target is only re-arrested every few seconds to avoid invoke spam.
local ArrestRange = 60   -- only auto-arrest targets within this many studs
local ArrestDelay = 0.1  -- seconds between arrest attempts
local arrestDebounce = {}

local function getNearestPlayer()
    local myChar = local_player.Character
    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHrp then return nil end

    local myTeam = local_player.Team
    local nearest, nearestDist = nil, ArrestRange

    for _, p in ipairs(players:GetPlayers()) do
        if p ~= local_player and (myTeam == nil or p.Team ~= myTeam) then
            local char = p.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local d = (hrp.Position - myHrp.Position).Magnitude
                if d <= nearestDist then
                    nearest, nearestDist = p, d
                end
            end
        end
    end
    return nearest
end

task.spawn(function()
    local remotes = replicated_storage:WaitForChild("Remotes", 10)
    local arrest_remote = remotes and remotes:WaitForChild("ArrestPlayer", 10)
    if not arrest_remote then return end

    while task.wait(ArrestDelay) do
        if AutoArrestEnabled then
            local target = getNearestPlayer()
            if target then
                local now = os.clock()
                if (not arrestDebounce[target]) or ((now - arrestDebounce[target]) > 3) then
                    arrestDebounce[target] = now
                    pcall(function()
                        arrest_remote:InvokeServer(target, 1)
                    end)
                end
            end
        end
    end
end)
