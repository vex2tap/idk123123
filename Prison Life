------------------------------------------------------------------------
-- AUTO JAIL BREAKOUT (PATHFINDING)
------------------------------------------------------------------------
local melee_remote = replicated_storage:WaitForChild("meleeEvent")

-- World position of the cell toilet (from the provided CFrame).
local TOILET_POSITION = Vector3.new(873.30127, 98.0302429, 2443.44434)

local function getChar()
    local character = local_player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    return character, humanoid, hrp
end

-- Pathfind + walk to a world position. Recomputes when blocked/stuck (doors, corners).
local function walkTo(targetPos, stillOn, maxAttempts)
    maxAttempts = maxAttempts or 8
    for _ = 1, maxAttempts do
        if stillOn and not stillOn() then return false end
        local _, humanoid, hrp = getChar()
        if not humanoid or not hrp then return false end
        if (hrp.Position - targetPos).Magnitude < 6 then return true end

        local path = pathfinding_service:CreatePath({
            AgentRadius = 2.5,
            AgentHeight = 5,
            AgentCanJump = true,
            AgentCanClimb = false,
            WaypointSpacing = 4,
        })

        local ok = pcall(function()
            path:ComputeAsync(hrp.Position, targetPos)
        end)

        if not ok or path.Status ~= Enum.PathStatus.Success then
            -- No path found: fall back to a direct move, then retry.
            humanoid:MoveTo(targetPos)
            humanoid.MoveToFinished:Wait()
        else
            local blocked = false
            local waypoints = path:GetWaypoints()
            for i = 2, #waypoints do
                if stillOn and not stillOn() then return false end
                local wp = waypoints[i]
                if wp.Action == Enum.PathWaypointAction.Jump then
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
                humanoid:MoveTo(wp.Position)

                local reached, t0 = false, os.clock()
                while os.clock() - t0 < 4 do
                    if stillOn and not stillOn() then return false end
                    local _, _, curHrp = getChar()
                    if not curHrp then return false end
                    if (curHrp.Position - wp.Position).Magnitude < 4.5 then
                        reached = true
                        break
                    end
                    task.wait(0.08)
                end

                if not reached then
                    blocked = true -- stuck on this waypoint; recompute from here
                    break
                end
            end
            if not blocked then return true end
        end
    end
    return false
end

-- Equip the Hammer tool once it lands in the backpack/character.
local function equipHammer()
    local tool, t = nil, 0
    repeat
        local backpack = local_player:FindFirstChildOfClass("Backpack")
        local character = local_player.Character
        tool = (backpack and backpack:FindFirstChild("Hammer"))
            or (character and character:FindFirstChild("Hammer"))
        if tool then break end
        task.wait(0.2)
        t = t + 0.2
    until t >= 6

    local character, humanoid = getChar()
    if tool and humanoid then
        if tool.Parent ~= character then
            pcall(function() humanoid:EquipTool(tool) end)
            if tool.Parent ~= character then tool.Parent = character end
        end
        return true
    end
    return false
end

local function findToilet()
    local pc = WorkspaceService:FindFirstChild("Prison_Cellblock")
    local cb = pc and pc:FindFirstChild("Cells_B")
    local c1 = cb and cb:FindFirstChild("cell1")
    local toilet = c1 and c1:FindFirstChild("Toilet")
    return toilet or WorkspaceService:FindFirstChild("Toilet", true)
end

local function runBreakoutSequence()
    if BreakoutRunning then return end
    BreakoutRunning = true

    local stillOn = function() return AutoBreakoutEnabled end

    -- 1) Grab the hammer. Walk to a physical Hammer giver if one exists, then fire the giver remote.
    local hammerGiver = WorkspaceService:FindFirstChild("Hammer", true)
    if hammerGiver then
        local pos = (hammerGiver:IsA("Model") and hammerGiver:GetPivot().Position)
            or (hammerGiver:IsA("BasePart") and hammerGiver.Position)
        if pos then walkTo(pos, stillOn) end
    end
    pcall(function()
        local args = { replicated_storage:WaitForChild("Hammer") }
        giver_remote:FireServer(unpack(args))
    end)
    task.wait(0.5)
    if not AutoBreakoutEnabled then BreakoutRunning = false return end

    -- 2) Pathfind to the toilet.
    walkTo(TOILET_POSITION, stillOn)
    if not AutoBreakoutEnabled then BreakoutRunning = false return end

    -- 3) Pull out the hammer.
    equipHammer()
    task.wait(0.3)

    -- 4) Smash the toilet while we are right next to it and the toggle is on.
    while AutoBreakoutEnabled do
        local toilet = findToilet()
        if not toilet then break end -- toilet gone => wall is open, we're out

        local _, _, hrp = getChar()
        if not hrp then break end

        local toiletPos = (toilet:IsA("Model") and toilet:GetPivot().Position)
            or (toilet:IsA("BasePart") and toilet.Position) or TOILET_POSITION
        if (hrp.Position - toiletPos).Magnitude > 10 then
            walkTo(toiletPos, stillOn)
        end

        local args = { toilet, 1, 1 }
        pcall(function() melee_remote:FireServer(unpack(args)) end)
        task.wait(0.1)
    end

    BreakoutRunning = false
end

