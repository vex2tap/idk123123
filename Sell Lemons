-- REBIRTH TIMING LOOP
task.spawn(function()
    local lastRebirthTime = 0
    while true do
        local currentTime = os.time()
        if states.AutoRebirth and not states.EmergencyPause then
            if (currentTime - lastRebirthTime) >= configuration.RebirthCooldown then
                local dynamicTycoon = getMyTycoon()
                local remotes = dynamicTycoon and dynamicTycoon:FindFirstChild("Remotes")
                local rebirthRemote = remotes and remotes:FindFirstChild("Rebirth")
                
                if rebirthRemote then
                    pcall(function()
                        if rebirthRemote:IsA("RemoteFunction") then
                            rebirthRemote:InvokeServer()
                        elseif rebirthRemote:IsA("RemoteEvent") then
                            rebirthRemote:FireServer()
                        end
                    end)
                    lastRebirthTime = currentTime
                end
            end
        else
            lastRebirthTime = 0
        end
        task.wait(1)
    end
end)

-- UNIFIED INCOME LOOP
task.spawn(function()
    local streams = {"LemonStand", "LemonDash", "LemonDepot", "LemonTrading", "LemonLabs"}
    local lastExecution = {}
    
    for _, stream in ipairs(streams) do
        lastExecution[stream] = 0
    end
    
    while true do
        if states.MasterIncome and not states.EmergencyPause then
            local myTycoon = getMyTycoon()
            local remote = myTycoon and myTycoon:FindFirstChild("Remotes") and myTycoon.Remotes:FindFirstChild("WakeIncomeStream")
            
            if remote then
                local now = os.clock()
                
                -- Fast track execution loop for Stand
                if now - lastExecution["LemonStand"] >= 0.5 then
                    pcall(function() remote:InvokeServer("LemonStand") end)
                    lastExecution["LemonStand"] = now
                end
                
                -- Extended interval checks for macro-streams
                for i = 2, #streams do
                    local name = streams[i]
                    if now - lastExecution[name] >= 15 then
                        pcall(function() remote:InvokeServer(name) end)
                        lastExecution[name] = now
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)

-- UNIFIED UPGRADES LOOP (NO MONEY CHECKS)
task.spawn(function()
    local upgradeTargets = {"Lemon Stand", "LemonDash", "Lemon Depot", "Lemon Trading"}
    
    while true do
        if states.MasterUpgrade and not states.EmergencyPause then
            local myTycoon = getMyTycoon()
            local purchases = myTycoon and myTycoon:FindFirstChild("Purchases")
            
            if purchases then
                for _, folderName in ipairs(upgradeTargets) do
                    local folder = purchases:FindFirstChild(folderName)
                    local targetRemote = folder and folder:FindFirstChild("Upgrade", true)
                    
                    if targetRemote and targetRemote:IsA("RemoteFunction") then
                        pcall(function() targetRemote:InvokeServer(1) end)
                    end
                end
            end
        end
        task.wait(0.2)
    end
end)

-- AUTOMATED PHONE OFFERS LOOP
task.spawn(function()
    while true do
        if states.AutoPhone and not states.EmergencyPause then
            local myTycoon = getMyTycoon()
            local remote = myTycoon and myTycoon:FindFirstChild("Remotes") and myTycoon.Remotes:FindFirstChild("PhoneOffer")
            if remote then 
                pcall(function() remote:FireServer("Accept") end) 
            end
        end
        task.wait(1)
    end
end)

-- PHYSICAL TOUCH ENGINE (MASTER BUY ALL)
task.spawn(function()
    while true do
        if states.AutoBuyAll and not states.EmergencyPause then
            local character = Player.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            
            local myTycoon = getMyTycoon()
            local buttonsFolder = myTycoon and (myTycoon:FindFirstChild("Purchases") or myTycoon:FindFirstChild("Buttons"))
            
            if rootPart and buttonsFolder then
                for _, item in ipairs(buttonsFolder:GetDescendants()) do
                    if item:IsA("BasePart") and item:FindFirstChildOfClass("TouchTransmitter") then
                        pcall(function()
                            firetouchinterest(item, rootPart, 0) -- Touch Start
                            task.wait()                          -- Engine frame alignment tick
                            firetouchinterest(item, rootPart, 1) -- Touch End
                        end)
                    end
                end
            end
        end
        task.wait(0.4)
    end
end)
