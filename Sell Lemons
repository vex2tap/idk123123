local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local VirtualUser = game:GetService("VirtualUser")

local Library = {}

function Library:CreateWindow(titleText)
    local Window = {}
    
    -- Root ScreenGui
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "PremiumUILibrary_V4"
    ScreenGui.ResetOnSpawn = false
    
    local success, err = pcall(function() ScreenGui.Parent = CoreGui end)
    if not success then 
        local localPlayer = Players.LocalPlayer or game:GetService("Players").LocalPlayer
        if localPlayer then
            ScreenGui.Parent = localPlayer:WaitForChild("PlayerGui")
        end
    end
    
    -- Main Window Frame
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Parent = ScreenGui
    MainFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    MainFrame.BorderColor3 = Color3.fromRGB(0, 255, 200)
    MainFrame.BorderSizePixel = 1
    MainFrame.Position = UDim2.new(0.3, 0, 0.3, 0)
    MainFrame.Size = UDim2.new(0, 450, 0, 300)
    MainFrame.Active = true
    
    local mainCorner = Instance.new("UICorner", MainFrame)
    mainCorner.CornerRadius = UDim.new(0, 10)
    
    -- Smooth Dragging
    local dragging, dragInput, dragStart, startPos
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    MainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- Header
    local Header = Instance.new("Frame")
    Header.Name = "Header"
    Header.Parent = MainFrame
    Header.BackgroundTransparency = 1
    Header.Size = UDim2.new(1, 0, 0, 40)
    
    local Title = Instance.new("TextLabel")
    Title.Name = "Title"
    Title.Parent = Header
    Title.BackgroundTransparency = 1
    Title.Position = UDim2.new(0, 15, 0, 0)
    Title.Size = UDim2.new(1, -30, 1, 0)
    Title.Font = Enum.Font.GothamBold
    Title.Text = string.upper(titleText)
    Title.TextColor3 = Color3.fromRGB(0, 255, 200)
    Title.TextSize = 13
    Title.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Left Sidebar Frame
    local Sidebar = Instance.new("Frame")
    Sidebar.Name = "Sidebar"
    Sidebar.Parent = MainFrame
    Sidebar.BackgroundColor3 = Color3.fromRGB(13, 13, 16)
    Sidebar.Position = UDim2.new(0, 0, 0, 40)
    Sidebar.Size = UDim2.new(0, 130, 1, -40)
    
    local sideCorner = Instance.new("UICorner", Sidebar)
    sideCorner.CornerRadius = UDim.new(0, 10)
    
    local sideCover = Instance.new("Frame", MainFrame)
    sideCover.Name = "SidebarVisualFix"
    sideCover.Size = UDim2.new(0, 15, 0, 260)
    sideCover.Position = UDim2.new(0, 115, 0, 40)
    sideCover.BackgroundColor3 = Sidebar.BackgroundColor3
    sideCover.BorderSizePixel = 0
    
    local TabButtonContainer = Instance.new("Frame")
    TabButtonContainer.Name = "TabButtonContainer"
    TabButtonContainer.Parent = Sidebar
    TabButtonContainer.BackgroundTransparency = 1
    TabButtonContainer.Size = UDim2.new(1, 0, 1, 0)
    
    local SidebarLayout = Instance.new("UIListLayout", TabButtonContainer)
    SidebarLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    SidebarLayout.Padding = UDim.new(0, 6)
    
    -- Content Pages Holder
    local Container = Instance.new("Frame")
    Container.Name = "Container"
    Container.Parent = MainFrame
    Container.BackgroundTransparency = 1
    Container.Position = UDim2.new(0, 140, 0, 45)
    Container.Size = UDim2.new(1, -150, 1, -50)
    
    local tabs = {}
    local firstTab = true
    
    function Window:CreateTab(tabName)
        local Tab = {}
        
        local TabBtn = Instance.new("TextButton")
        TabBtn.Name = tabName .. "Btn"
        TabBtn.Parent = TabButtonContainer
        TabBtn.Size = UDim2.new(0, 120, 0, 35)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Font = Enum.Font.GothamSemibold
        TabBtn.Text = tabName
        TabBtn.TextSize = 11
        
        local Page = Instance.new("ScrollingFrame")
        Page.Name = tabName .. "Page"
        Page.Parent = Container
        Page.BackgroundTransparency = 1
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.CanvasSize = UDim2.new(0, 0, 0, 0)
        Page.ScrollBarThickness = 3
        Page.ScrollBarImageColor3 = Color3.fromRGB(0, 255, 200)
        
        local PageLayout = Instance.new("UIListLayout", Page)
        PageLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        PageLayout.Padding = UDim.new(0, 6)
        
        PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Page.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y + 10)
        end)
        
        if firstTab then
            Page.Visible = true
            TabBtn.TextColor3 = Color3.fromRGB(0, 255, 200)
            firstTab = false
        else
            Page.Visible = false
            TabBtn.TextColor3 = Color3.fromRGB(140, 140, 145)
        end
        
        table.insert(tabs, {Button = TabBtn, Page = Page})
        
        TabBtn.MouseButton1Click:Connect(function()
            for _, t in ipairs(tabs) do
                if t.Button == TabBtn then
                    t.Page.Visible = true
                    t.Button.TextColor3 = Color3.fromRGB(0, 255, 200)
                else
                    t.Page.Visible = false
                    t.Button.TextColor3 = Color3.fromRGB(140, 140, 145)
                end
            end
        end)
        
        function Tab:CreateToggle(toggleText, defaultState, callback)
            local state = defaultState or false
            
            local ToggleFrame = Instance.new("Frame")
            ToggleFrame.Size = UDim2.new(1, -6, 0, 42)
            ToggleFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
            
            local toggleCorner = Instance.new("UICorner", ToggleFrame)
            toggleCorner.CornerRadius = UDim.new(0, 6)
            
            local Label = Instance.new("TextLabel")
            Label.Parent = ToggleFrame
            Label.BackgroundTransparency = 1
            Label.Position = UDim2.new(0, 12, 0, 0)
            Label.Size = UDim2.new(1, -70, 1, 0)
            Label.Font = Enum.Font.GothamSemibold
            Label.Text = toggleText
            Label.TextColor3 = Color3.fromRGB(220, 220, 225)
            Label.TextSize = 12
            Label.TextXAlignment = Enum.TextXAlignment.Left
            
            local SwitchBg = Instance.new("Frame")
            SwitchBg.Size = UDim2.new(0, 38, 0, 20)
            SwitchBg.Position = UDim2.new(1, -50, 0.5, -10)
            SwitchBg.Parent = ToggleFrame
            
            local bgCorner = Instance.new("UICorner", SwitchBg)
            bgCorner.CornerRadius = UDim.new(1, 0)
            
            local SliderCircle = Instance.new("Frame")
            SliderCircle.Size = UDim2.new(0, 14, 0, 14)
            SliderCircle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            SliderCircle.Parent = SwitchBg
            
            local circleCorner = Instance.new("UICorner", SliderCircle)
            circleCorner.CornerRadius = UDim.new(1, 0)
            
            local Hitbox = Instance.new("TextButton")
            Hitbox.Size = UDim2.new(1, 0, 1, 0)
            Hitbox.BackgroundTransparency = 1
            Hitbox.Text = ""
            Hitbox.Parent = ToggleFrame
            
            local tweenInfo = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            
            local function updateToggleVisual(instant)
                local targetPos = state and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)
                local targetColor = state and Color3.fromRGB(46, 204, 113) or Color3.fromRGB(60, 60, 65)
                
                if instant then
                    SliderCircle.Position = targetPos
                    SwitchBg.BackgroundColor3 = targetColor
                else
                    TweenService:Create(SliderCircle, tweenInfo, {Position = targetPos}):Play()
                    TweenService:Create(SwitchBg, tweenInfo, {BackgroundColor3 = targetColor}):Play()
                end
            end
            
            Hitbox.MouseButton1Click:Connect(function()
                state = not state
                updateToggleVisual(false)
                task.spawn(callback, state)
            end)
            
            updateToggleVisual(true)
            ToggleFrame.Parent = Page
            return ToggleFrame
        end

        function Tab:CreateTextBox(boxPlaceholder, defaultText, callback)
            local BoxFrame = Instance.new("Frame")
            BoxFrame.Size = UDim2.new(1, -6, 0, 42)
            BoxFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
            
            local boxCorner = Instance.new("UICorner", BoxFrame)
            boxCorner.CornerRadius = UDim.new(0, 6)
            
            local Label = Instance.new("TextLabel")
            Label.Parent = BoxFrame
            Label.BackgroundTransparency = 1
            Label.Position = UDim2.new(0, 12, 0, 0)
            Label.Size = UDim2.new(0.5, 0, 1, 0)
            Label.Font = Enum.Font.GothamSemibold
            Label.Text = boxPlaceholder
            Label.TextColor3 = Color3.fromRGB(220, 220, 225)
            Label.TextSize = 12
            Label.TextXAlignment = Enum.TextXAlignment.Left
            
            local InputBox = Instance.new("TextBox")
            InputBox.Size = UDim2.new(0, 100, 0, 26)
            InputBox.Position = UDim2.new(1, -112, 0.5, -13)
            InputBox.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
            InputBox.BorderSizePixel = 0
            InputBox.Font = Enum.Font.Gotham
            InputBox.Text = tostring(defaultText)
            InputBox.PlaceholderText = "..."
            InputBox.TextColor3 = Color3.fromRGB(0, 255, 200)
            InputBox.TextSize = 11
            InputBox.Parent = BoxFrame
            
            local inputCorner = Instance.new("UICorner", InputBox)
            inputCorner.CornerRadius = UDim.new(0, 4)
            
            InputBox.FocusLost:Connect(function(enterPressed)
                task.spawn(callback, InputBox.Text)
            end)
            
            BoxFrame.Parent = Page
            return BoxFrame
        end
        
        return Tab
    end
    
    return Window
end

-- ============================================================================
-- SAFE RUNTIME INITIALIZATION
-- ============================================================================

local Player = Players.LocalPlayer
local states = {
    MasterIncome = false,
    MasterUpgrade = false,
    AutoBuyAll = false,
    AutoRebirth = false,
    AutoPhone = false,
    EmergencyPause = false
}

local configuration = {
    RebirthCooldown = 600
}

local function getMyTycoon()
    for _, obj in ipairs(workspace:GetChildren()) do
        if string.find(string.lower(obj.Name), "tycoon") then
            local ownerAttr = obj:GetAttribute("Owner")
            local ownerValueObj = obj:FindFirstChild("Owner") or obj:FindFirstChild("OwnerValue")
            
            if ownerAttr == Player.Name or ownerAttr == Player.UserId then
                return obj
            elseif ownerValueObj and (ownerValueObj.Value == Player or ownerValueObj.Value == Player.Name or ownerValueObj.Value == tostring(Player.UserId)) then
                return obj
            end
        end
    end
    return nil
end

