        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= Client and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and not table.find(getgenv().Whitelisted, p.Name) then
                local tarPart = p.Character.HumanoidRootPart
                swingKnife()
                firetouchinterest(tarPart, knife.Handle, 1)
                firetouchinterest(tarPart, knife.Handle, 0)
            end
        end
    end
end

