local function executeSheriffSnipe()
    local gun = Client.Backpack:FindFirstChild("Gun") or (Client.Character and Client.Character:FindFirstChild("Gun"))
    if not gun or not RootPart then return end
    
    local targetName = GetMurderer()
    if targetName and Players:FindFirstChild(targetName) then
        local targetPlayer = Players[targetName]
        if targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local originalPosition = RootPart.CFrame
            local targetPos = targetPlayer.Character.HumanoidRootPart.Position
            
            if gun.Parent == Client.Backpack and Character:FindFirstChild("Humanoid") then
                Character.Humanoid:EquipTool(gun)
            end
            task.wait(0.05)
            
            Client.Character:PivotTo(CFrame.new(targetPos + Vector3.new(0, 4, 0)))
            task.wait(0.05)
            
            local shootEvent = ReplicatedStorage:FindFirstChild("ShootGun", true) or ReplicatedStorage:FindFirstChild("Shoot", true)
            if shootEvent and shootEvent:IsA("RemoteEvent") then
                shootEvent:FireServer(targetPos, targetPos)
            end
            
            task.wait(0.05)
            Client.Character:PivotTo(originalPosition)
        end
    end
end

-- Main Processing Loop
task.spawn(function()
    local currentContainer = nil
    while true do
        task.wait(0.05)
        
        if not getgenv().Autofarm then 
            if currentContainer then
                rt.Disconnect(rt.Added)
                rt.Disconnect(rt.Removing)
                rt.octree:ClearAllNodes()
                currentContainer = nil
                rt.IsHidden = false
                if RootPart then RootPart.Anchored = false end
            end
            continue 
        end

        local map = rt:Map()
        local container = map and map:FindFirstChild("CoinContainer")

        if not container or not RootPart or #container:GetChildren() == 0 then
            if currentContainer then
                rt.Disconnect(rt.Added)
                rt.Disconnect(rt.Removing)
                rt.octree:ClearAllNodes()
                currentContainer = nil
                rt.IsHidden = false
            end
            task.wait(0.5)
            continue
        end

        if container ~= currentContainer or (tick() - LastFarmedTimestamp > 4.5) then
            currentContainer = container
            rt.coinContainer = container
            rt.touchedCoins = {} 
            populateOctree()
            LastFarmedTimestamp = tick()

            rt.Disconnect(rt.Added)
            rt.Added = container.DescendantAdded:Connect(function(descendant)
                if descendant:IsA("TouchTransmitter") then
                    local parentCoin = descendant.Parent
                    if parentCoin and not isCoinTouched(parentCoin) then
                        rt.octree:CreateNode(parentCoin.Position, parentCoin)
                        setupTouchTracking(parentCoin)
                    end
                end
            end)

            rt.Disconnect(rt.Removing)
            rt.Removing = container.DescendantRemoving:Connect(function(descendant)
                if descendant:IsA("TouchTransmitter") or descendant:IsA("BasePart") then
                    local parentCoin = descendant:IsA("TouchTransmitter") and descendant.Parent or descendant
                    if parentCoin then markCoinAsTouched(parentCoin) end
                end
            end)
        end

        if checkIfBagIsFull() then
            local hasKnife = Client.Backpack:FindFirstChild("Knife") or (Character and Character:FindFirstChild("Knife"))
            
            if getgenv().KillAllOnFull and hasKnife then
                executeGlobalKillAll()
                task.wait(0.5)
            end
            
            -- NEW SYSTEM: Void on Full vs Sky Teleportation Check
            if getgenv().VoidOnFull then
                if Character and RootPart then
                    RootPart.Anchored = false
                    -- Drive the player instantly through map clips downward into the void limit
                    local voidTarget = RootPart.Position - Vector3.new(0, 350, 0)
                    moveToPositionSlowly(voidTarget, 1.5, nil)
                end
            else
                if not rt.IsHidden then
                    rt.SavedSkyPos = RootPart.Position + Vector3.new(0, 70, 0)
                    local duration = (RootPart.Position - rt.SavedSkyPos).Magnitude / rt.walkspeed
                    
                    moveToPositionSlowly(rt.SavedSkyPos, duration, nil)
                    if RootPart then RootPart.Anchored = true end
                    rt.IsHidden = true
                end
            end
            task.wait(0.5) 
            continue
        else
            if rt.IsHidden then
                if RootPart then RootPart.Anchored = false end
                rt.IsHidden = false
            end
        end

        -- Find closest coin via spatial querying
        local nodes = rt.octree:GetNearest(RootPart.Position, rt.radius, 15)
        local targetCoin = nil

        for _, node in ipairs(nodes) do
            local coin = node.Object
            if coin and coin:IsA("BasePart") and coin:IsDescendantOf(workspace) and not isCoinTouched(coin) then
                if getgenv().AvoidMurderer then
                    local mName = GetMurderer()
                    local mPlayer = mName and Players:FindFirstChild(mName)
                    local mChar = mPlayer and mPlayer.Character
                    local mRoot = mChar and mChar:FindFirstChild("HumanoidRootPart")
                    
                    if mRoot and (coin.Position - mRoot.Position).Magnitude < 50 then
                        continue
                    end
                end
                targetCoin = coin
                break
            end
        end

        if targetCoin then
            if RootPart then RootPart.Anchored = false end
            local closestCoinPosition = targetCoin.Position + Vector3.new(0, 3, 0)
            local duration = (RootPart.Position - closestCoinPosition).Magnitude / rt.walkspeed

            LastFarmedTimestamp = tick() 
            moveToPositionSlowly(closestCoinPosition, duration, targetCoin)
            task.wait(0.02) 
            markCoinAsTouched(targetCoin)
        else
            if RootPart then RootPart.Anchored = false end
            local items = container:GetChildren()
            if #items > 0 then
                populateOctree() 
            end
            task.wait(0.2) 
        end
    end
end)

