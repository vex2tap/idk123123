-- NETWORKING HANDLERS
local MainHook
MainHook = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if not checkcaller() and method == "InvokeServer" then
        if tostring(self) == "ShootGun" and getgenv().SheriffAim then
            local targetName = GetMurderer()
            if targetName and Players:FindFirstChild(targetName) then
                local tarChar = Players[targetName].Character
                if tarChar and tarChar:FindFirstChild("PrimaryPart") then
                    local root = tarChar.PrimaryPart
                    local velocity = root.AssemblyLinearVelocity
                    args[2] = root.Position + (velocity * Vector3.new(getgenv().GunAccuracy / 200, 0, getgenv().GunAccuracy / 200))
                end
            end
        elseif tostring(self) == "GetChance" then
            task.wait(13)
            Murderer = GetMurderer()
            Sheriff = GetSheriff()
            CanGrab = true
        end
    end
    return MainHook(self, unpack(args))
end)

task.spawn(function()
    while task.wait(2) do
        pcall(function()
            Murderer = GetMurderer()
            Sheriff = GetSheriff()
        end)
    end
end)
