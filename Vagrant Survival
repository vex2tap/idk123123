hook(hs);

-- ESP System
local activeESP = {}
local function createESP(model, isEnemy)
    if activeESP[model] or not getgenv().ESPEnabled then return end
    local highlight = Instance.new("Highlight")
    highlight.Name = "CleanESP"
    highlight.FillColor = isEnemy and Color3.fromRGB(255, 60, 60) or Color3.fromRGB(60, 255, 60)
    highlight.FillTransparency = 0.6
    highlight.OutlineColor = isEnemy and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0)
    highlight.OutlineTransparency = 0.1
    highlight.Adornee = model
    highlight.Parent = model
    activeESP[model] = highlight
end

local function removeESP(model)
    if activeESP[model] then activeESP[model]:Destroy(); activeESP[model] = nil; end
end

local function setupFolderTracking(folder, isEnemy)
    for _, child in ipairs(folder:GetChildren()) do if child:IsA("Model") and child ~= plr.Character then createESP(child, isEnemy) end end
    folder.ChildAdded:Connect(function(child) task.wait(0.1); if child:IsA("Model") and child ~= plr.Character then createESP(child, isEnemy) end end)
    folder.ChildRemoved:Connect(function(child) removeESP(child) end)
end
setupFolderTracking(Chars, false)
setupFolderTracking(Enemies, true)

-- Watch for ESP Toggle changes to refresh states
task.spawn(function()
    while task.wait(0.5) do
        if not getgenv().ESPEnabled then
            for model, _ in pairs(activeESP) do removeESP(model) end
        else
            for _, child in ipairs(Chars:GetChildren()) do if child:IsA("Model") and child ~= plr.Character then createESP(child, false) end end
            for _, child in ipairs(Enemies:GetChildren()) do if child:IsA("Model") and child ~= plr.Character then createESP(child, true) end end
        end
    end
end)

