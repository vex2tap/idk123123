local function discoverEquippedWeapon(targetModel, targetPlayer)
    local characterWeapons = {}
    for _, item in ipairs(targetModel:GetChildren()) do
        if item:IsA("Model") or item:IsA("Folder") then
            characterWeapons[item.Name:lower()] = item.Name
        end
    end

    if targetPlayer then
        local backpack = targetPlayer:FindFirstChildOfClass("Backpack")
        if backpack then
            for _, config in ipairs(ic:GetChildren()) do
                local weaponName = config.Name:lower()
                
                if characterWeapons[weaponName] then
                    return characterWeapons[weaponName]
                end
                
                local inventoryInstance = backpack:FindFirstChild(config.Name)
                if not inventoryInstance and targetModel:FindFirstChild(config.Name, true) then
                    return config.Name
                end
            end
        end
    end

    for _, config in ipairs(ic:GetChildren()) do
        if targetModel:FindFirstChild(config.Name, true) then
            return config.Name
        end
    end

    return "UNARMED"
end

-- Runtime Interface Update Loop
local isUiShowing = false
local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

RunService.RenderStepped:Connect(function()
    local mouseLoc = isMobile and Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2) or UIS:GetMouseLocation()
    FOVCircle.Position = mouseLoc
    FOVCircle.Radius = getgenv().fov
    FOVCircle.Visible = getgenv().FOVVisible
    
    local currentTargetPart = getTarget(cam.CFrame.Position)
    if currentTargetPart and currentTargetPart.Parent then
        local targetModel = currentTargetPart.Parent
        local targetPlayer = Players:GetPlayerFromCharacter(targetModel)
        
        local textName = string.upper(targetModel.Name)
        local textLevel = "LEVEL: --"
        local discoveredWeapon = discoverEquippedWeapon(targetModel, targetPlayer)
        local textWeapon = "WEAPON: " .. string.upper(discoveredWeapon)
        
        if targetPlayer then
            local stats = targetPlayer:FindFirstChild("leaderstats")
            local lvlObj = stats and (stats:FindFirstChild("Level") or stats:FindFirstChild("Lvl"))
            if lvlObj then
                textLevel = "LEVEL: " .. tostring(lvlObj.Value)
            end
            NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            local hum = targetModel:FindFirstChildOfClass("Humanoid")
            if hum then
                textLevel = "HP: " .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
            end
            NameLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            textName = "[NPC] " .. textName
        end
        
        NameLabel.Text = textName
        LevelLabel.Text = textLevel
        WeaponLabel.Text = textWeapon
        
        if not isUiShowing and getgenv().SilentAimEnabled then
            isUiShowing = true
            HUDFrame.Visible = true
            HUDFrame.Size = UDim2.new(0, 340, 0, 0)
            TweenService:Create(HUDFrame, tweenInfo, {Size = UDim2.new(0, 340, 0, 65)}):Play()
        end
    else
        if isUiShowing or not getgenv().SilentAimEnabled then
            isUiShowing = false
            local closeTween = TweenService:Create(HUDFrame, tweenInfo, {Size = UDim2.new(0, 340, 0, 0)})
            closeTween.Completed:Connect(function()
                if not isUiShowing then HUDFrame.Visible = false end
            end)
            closeTween:Play()
        end
    end
end)
