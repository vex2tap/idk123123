local function updateFillLabel()
    local current, max = getFillStatus()
    if current and max then
        fillLabel.Text = "📦 Fill: " .. current .. "/" .. max
    else
        fillLabel.Text = "📦 Fill: N/A"
    end
end

local function updateCycleUI()
    currentCycleLabel.Text = "📊 Current Cycle: " .. cyclesThisBatch .. "/" .. CYCLES_BEFORE_SELL
    totalCycleLabel.Text = "🔄 Total Cycles: " .. totalCycles
end

function startLoop()
    if running then return end
    if not SandPos or not WaterPos then
        statusLabel.Text = "⚠️ Set Sand AND Water positions first!"
        return
    end
    currentTool = findPanTool()
    if not currentTool then
        statusLabel.Text = "⚠️ No pan equipped"
        toolLabel.Text = "🔧 Tool: None"
        return
    end
    toolLabel.Text = "🔧 Tool: " .. currentTool.Name
    running = true
    toggleButton.Text = "⏹️ Stop"
    toggleButton.BackgroundColor3 = Color3.fromRGB(239, 68, 68)
    statusLabel.Text = "🔄 Running..."
    cyclesThisBatch = 0
    totalCycles = 0
    updateCycleUI()
    
    loopTask = task.spawn(function()
        while running do
            currentTool = findPanTool()
            if not currentTool then
                statusLabel.Text = "⚠️ Lost tool"
                running = false
                break
            end
            toolLabel.Text = "🔧 Tool: " .. currentTool.Name

            -- Step 1: Farm in Sand until full
            statusLabel.Text = "🔄 Running..."
            locationLabel.Text = "📍 Location: Sand (Filling)"
            farmUntilFull(SandPos, currentTool)
            if not running then break end

            -- Step 2: Rinse in Water until empty (WITH RAPID CLICKING)
            locationLabel.Text = "📍 Location: Water (Rinsing)"
            rinseUntilEmpty(WaterPos, currentTool)
            if not running then break end

            -- Increment cycles
            cyclesThisBatch = cyclesThisBatch + 1
            totalCycles = totalCycles + 1
            updateCycleUI()

            -- Step 3: If we've reached the cycle target, go sell
            if cyclesThisBatch >= CYCLES_BEFORE_SELL then
                locationLabel.Text = "📍 Location: Selling"
                doSell(SELL_DURATION, SELL_INTERVAL)
                if not running then break end
                cyclesThisBatch = 0
                updateCycleUI()
            end
            
            task.wait(0.3)
        end
        running = false
        releaseClick()
        toggleButton.Text = "▶️ Start"
        toggleButton.BackgroundColor3 = Color3.fromRGB(168, 85, 247)
        if statusLabel.Text == "🔄 Running..." or statusLabel.Text == "⏹️ Stopped" then
            statusLabel.Text = "⏹️ Stopped"
        end
    end)
end

function stopLoop()
    running = false
    releaseClick()
    if loopTask then task.cancel(loopTask) end
    toggleButton.Text = "▶️ Start"
    toggleButton.BackgroundColor3 = Color3.fromRGB(168, 85, 247)
    statusLabel.Text = "⏹️ Stopped"
end

toggleButton.MouseButton1Click:Connect(function()
    if running then
        stopLoop()
    else
        startLoop()
    end
end)

