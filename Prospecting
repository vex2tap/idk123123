-- ========== CORE GAME UTILITIES ==========
local function findPanTool()
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("Tool") then
            local scripts = child:FindFirstChild("Scripts")
            if scripts and scripts:FindFirstChild("Pan") and scripts:FindFirstChild("Shake") and scripts:FindFirstChild("Collect") then
                return child
            end
        end
    end
    return nil
end

local function getFillStatus()
    local playerGui = localPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil, nil end
    local toolUI = playerGui:FindFirstChild("ToolUI")
    if not toolUI then return nil, nil end
    local fillingPan = toolUI:FindFirstChild("FillingPan")
    if not fillingPan then return nil, nil end
    local fillText = fillingPan:FindFirstChild("FillText")
    if not fillText or not fillText:IsA("TextLabel") then return nil, nil end
    local text = fillText.Text
    local current, max = text:match("(%d+)/(%d+)")
    if current and max then return tonumber(current), tonumber(max) end
    return nil, nil
end

local function fireRemotes(tool)
    if not tool then return end
    local scripts = tool:FindFirstChild("Scripts")
    if not scripts then return end
    local panRemote = scripts:FindFirstChild("Pan")
    local shakeRemote = scripts:FindFirstChild("Shake")
    local collectRemote = scripts:FindFirstChild("Collect")
    
    if panRemote then pcall(panRemote.InvokeServer, panRemote) end
    if shakeRemote then pcall(shakeRemote.FireServer, shakeRemote) end
    if collectRemote then pcall(collectRemote.InvokeServer, collectRemote, 1, false) end
end

local function sellAll()
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local remotes = replicatedStorage:FindFirstChild("Remotes") or replicatedStorage:FindFirstChild("Remote")
    if not remotes then return false end
    local shop = remotes:FindFirstChild("Shop")
    if not shop then return false end
    local sellRemote = shop:FindFirstChild("SellAll") or shop:FindFirstChild("Sell")
    if sellRemote then
        local success, _ = pcall(function() return sellRemote:InvokeServer() end)
        return success
    end
    return false
end

local function getClosestMerchantPosition()
    if not rootPart then return nil end
    local closestPos = nil
    local shortestDistance = math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if string.lower(obj.Name) == "merchant" then
            local targetPos = obj:IsA("BasePart") and obj.Position or (obj:IsA("Model") and obj:GetPivot().Position)
            if targetPos then
                local distance = (rootPart.Position - targetPos).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestPos = targetPos
                end
            end
        end
    end
    return closestPos
end

local function tweenToPosition(targetPos)
    if not rootPart or not targetPos then return end
    local distance = (rootPart.Position - targetPos).Magnitude
    local duration = distance / TWEEN_SPEED
    rootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0,0,0)
    
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    local tween = TweenService:Create(rootPart, tweenInfo, {CFrame = CFrame.new(targetPos + Vector3.new(0, 1.5, 0))})
    
    local transitNoclip = RunService.Stepped:Connect(function()
        if character then
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
    
    tween:Play()
    tween.Completed:Wait()
    transitNoclip:Disconnect()
    rootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
    task.wait(0.1)
end

local function holdClick() VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1) end
local function releaseClick() VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1) end

local function farmUntilFull(pos, tool)
    tweenToPosition(pos)
    task.wait(0.1) 
    holdClick()
    while true do
        if not running or not character or not character:FindFirstChild("HumanoidRootPart") then break end
        local current, max = getFillStatus()
        if current and max and current >= max then break end
        fireRemotes(tool)
        task.wait(FIRE_INTERVAL)
    end
    releaseClick() 
end

local function rinseUntilEmpty(pos, tool)
    tweenToPosition(pos)
    task.wait(0.1)
    while true do
        if not running or not character or not character:FindFirstChild("HumanoidRootPart") then break end
        local current, max = getFillStatus()
        if current and max and current == 0 then break end
        holdClick() task.wait(CLICK_INTERVAL / 2) releaseClick()
        fireRemotes(tool) task.wait(CLICK_INTERVAL / 2)
    end
    releaseClick() 
end

-- ================= AUTOMATION LOOP SYSTEM FUNCTIONS =================
local cyclesThisBatch = 0
local totalCycles = 0

-- UI Forward Declarations (Updated dynamically by loop)
local runStatusLabel, liveLocationLabel, liveFillLabel, liveCyclesLabel

local function refreshAnalyticsDisplay()
    if not liveFillLabel or not liveCyclesLabel then return end
    local current, max = getFillStatus()
    if current and max then liveFillLabel.Text = "Cargo Matrix Load: 📦 Load: " .. current .. "/" .. max else liveFillLabel.Text = "Cargo Matrix Load: 📦 Load: 0/0" end
    liveCyclesLabel.Text = "Batch Sequence loops: 📊 Cycles: " .. cyclesThisBatch .. "/" .. CYCLES_BEFORE_SELL .. " (Sessions: " .. totalCycles .. ")"
end

local function doSell(sellDuration, sellInterval)
    local sellPos = getClosestMerchantPosition()
    if not sellPos then
        if runStatusLabel then runStatusLabel.Text = "Engine Matrix: ⚠️ RUNTIME CRITICAL - MERCHANT MISSING" end
        running = false
        return false 
    end
    
    releaseClick() 
    if liveLocationLabel then liveLocationLabel.Text = "Target Vector: 📍 Synchronizing Merchant Hub" end
    tweenToPosition(sellPos)
    
    local startTime = tick()
    local lastSellInvoke = 0
    
    local lockConnection = RunService.Stepped:Connect(function()
        if (tick() - startTime) >= sellDuration or not running then return end
        if character then
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
        if rootPart then
            rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            rootPart.CFrame = CFrame.new(sellPos + Vector3.new(0, 0.5, 0))
        end
    end)
    
    while (tick() - startTime) < sellDuration do
        if not running then break end
        if (tick() - lastSellInvoke) >= sellInterval then
            sellAll()         
            lastSellInvoke = tick()
        end
        task.wait(0.1) 
    end
    
    lockConnection:Disconnect()
    return true
end

local function startLoop()
    if running then return end
    if not SandPos or not WaterPos then
        if runStatusLabel then runStatusLabel.Text = "Engine Matrix: ⚠️ COMPILER VOID - VECTORS EMPTY" end
        return
    end
    local currentTool = findPanTool()
    if not currentTool then
        if runStatusLabel then runStatusLabel.Text = "Engine Matrix: ⚠️ IO ACCESS BLOCK - NO PAN EQUIPPED" end
        return
    end
    
    running = true
    if runStatusLabel then runStatusLabel.Text = "Engine Matrix: ⚡ Automated Execution Sequences Live" end
    cyclesThisBatch = 0
    refreshAnalyticsDisplay()
    
    loopTask = task.spawn(function()
        while running do
            currentTool = findPanTool()
            if not currentTool then
                if runStatusLabel then runStatusLabel.Text = "Engine Matrix: ⚠️ PROCESS SHUTDOWN - PAN UNRESOLVED" end
                running = false
                break
            end

            if liveLocationLabel then liveLocationLabel.Text = "Target Vector: 📍 Extracting Ground Strata" end
            farmUntilFull(SandPos, currentTool)
            if not running then break end

            if liveLocationLabel then liveLocationLabel.Text = "Target Vector: 📍 Washing Processing Matrix" end
            rinseUntilEmpty(WaterPos, currentTool)
            if not running then break end

            cyclesThisBatch = cyclesThisBatch + 1
            totalCycles = totalCycles + 1
            refreshAnalyticsDisplay()

            if cyclesThisBatch >= CYCLES_BEFORE_SELL then
                local sellSuccess = doSell(SELL_DURATION, SELL_INTERVAL)
                if not sellSuccess or not running then break end
                cyclesThisBatch = 0
                refreshAnalyticsDisplay()
            end
            task.wait(0.3)
        end
        running = false
    end)
end

local function stopLoop()
    running = false
    releaseClick()
    if loopTask then task.cancel(loopTask) end
    if runStatusLabel then runStatusLabel.Text = "Engine Matrix: ⏹️ Sequence Suspended Safely" end
end


