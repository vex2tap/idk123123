    slideFill.BorderSizePixel = 0
    slideFill.Parent = slideTrack
    Instance.new("UICorner", slideFill).CornerRadius = UDim.new(1,0)

    local isSliding = false
    local function updateSlider(input)
        local absPos = slideTrack.AbsolutePosition.X
        local absSize = slideTrack.AbsoluteSize.X
        local percentage = math.clamp((input.Position.X - absPos) / absSize, 0, 1)
        slideFill.Size = UDim2.new(percentage, 0, 1, 0)
        local calculatedVal = math.round(min + (percentage * (max - min)))
        valueLabel.Text = tostring(calculatedVal)
        callback(calculatedVal)
    end

    slideTrack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then isSliding = true updateSlider(input) end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isSliding and input.UserInputType == Enum.UserInputType.MouseMovement then updateSlider(input) end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then isSliding = false end
    end)
end

