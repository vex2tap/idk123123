-- ========== DETECT EQUIPPED PAN ==========
local function findPanTool()
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("Tool") then
            local scripts = child:FindFirstChild("Scripts")
            if scripts and scripts:FindFirstChild("Pan") and scripts:FindFirstChild("Shake") and scripts:FindFirstChild("Collect") then
                return child
            end
        end
    end
    return nil
end

-- ========== GET FILL STATUS ==========
local function getFillStatus()
    local playerGui = localPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil, nil end
    local toolUI = playerGui:FindFirstChild("ToolUI")
    if not toolUI then return nil, nil end
    local fillingPan = toolUI:FindFirstChild("FillingPan")
    if not fillingPan then return nil, nil end
    local fillText = fillingPan:FindFirstChild("FillText")
    if not fillText or not fillText:IsA("TextLabel") then return nil, nil end
    local text = fillText.Text
    local current, max = text:match("(%d+)/(%d+)")
    if current and max then
        return tonumber(current), tonumber(max)
    end
    return nil, nil
end

-- ========== REMOTE FUNCTIONS ==========
local function getRemotes(tool)
    if not tool then return nil, nil, nil end
    local scripts = tool:FindFirstChild("Scripts")
    if not scripts then return nil, nil, nil end
    return scripts:FindFirstChild("Pan"),
           scripts:FindFirstChild("Shake"),
           scripts:FindFirstChild("Collect")
end

local function fireRemotes(tool)
    if not tool then return end
    local panRemote, shakeRemote, collectRemote = getRemotes(tool)
    if panRemote then pcall(panRemote.InvokeServer, panRemote) end
    if shakeRemote then pcall(shakeRemote.FireServer, shakeRemote) end
    if collectRemote then pcall(collectRemote.InvokeServer, collectRemote, 1, false) end
end

-- ========== SELLING ==========
local function getSellPosition()
    local map = workspace:FindFirstChild("Map")
    if not map then return nil end
    local starterTown = map:FindFirstChild("StarterTown")
    if not starterTown then return nil end
    local details = starterTown:FindFirstChild("Details")
    if not details then return nil end
    local children = details:GetChildren()
    if #children >= 12 then
        local sellPart = children[12]
        if sellPart:IsA("BasePart") then
            return sellPart.Position
        end
    end
    return nil
end

local function sellAll()
    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
    if remote then remote = remote:FindFirstChild("Shop") end
    if remote then remote = remote:FindFirstChild("SellAll") end
    if remote then
        pcall(remote.InvokeServer, remote)
        return true
    end
    return false
end

-- ========== FIXED ANTI-RUBBERBAND TELEPORT ==========
local function teleport(pos)
    if pos and rootPart then
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        
        rootPart.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
        
        task.wait(0.1)
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        task.wait(0.1) 
    end
end

-- ========== MOUSE ACTIONS ==========
local function holdClick()
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
end

local function releaseClick()
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
end

-- ========== FARM UNTIL FULL ==========
local function farmUntilFull(pos, tool)
    teleport(pos)
    print("Farming in Sand...")
    task.wait(0.2) 
    
    holdClick() -- Hold down click normally for sand filling
    
    while true do
        if not running or not character or not character:FindFirstChild("HumanoidRootPart") then break end
        
        local current, max = getFillStatus()
        if current and max then
            if current >= max then
                print("Pan full! Current:", current, "/", max)
                break
            end
        end
        
        fireRemotes(tool)
        task.wait(FIRE_INTERVAL)
    end
    
    releaseClick() 
end

-- ========== RINSE UNTIL EMPTY (CONSTANT CLICKING) ==========
local function rinseUntilEmpty(pos, tool)
    teleport(pos)
    print("Rinsing in Water...")
    task.wait(0.2)
    
    while true do
        if not running or not character or not character:FindFirstChild("HumanoidRootPart") then break end
        
        local current, max = getFillStatus()
        if current and max then
            if current == 0 then
                print("Pan empty! Current:", current, "/", max)
                break
            end
        end
        
        -- Simulate a rapid physical click cycle (Press -> Release)
        holdClick()
        task.wait(CLICK_INTERVAL / 2)
        releaseClick()
        
        fireRemotes(tool)
        task.wait(CLICK_INTERVAL / 2)
    end
    
    releaseClick() -- Safety release when moving to next phase
end

-- ========== LOCKED NPC SELL LOOP ==========
local function doSell(sellDuration, sellInterval)
    local sellPos = getSellPosition()
    if not sellPos then
        print("Sell position not found")
        return
    end
    
    print("Selling at NPC for", sellDuration, "seconds...")
    local start = tick()
    
    releaseClick() 
    
    while (tick() - start) < sellDuration do
        if not running then break end
        teleport(sellPos) 
        sellAll()         
        task.wait(sellInterval)
    end
    print("Selling complete.")
end

