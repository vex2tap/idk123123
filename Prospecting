local function buildMetric(text, y)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 0, 20)
    lbl.Position = UDim2.new(0, 0, 0, y)
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(180, 185, 195)
    lbl.Font = Enum.Font.GothamMedium
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = telemetryCard
    return lbl
end

runStatusLabel = buildMetric("Engine Matrix: ⏳ Standing By", 26)
liveLocationLabel = buildMetric("Target Vector: 📍 Mapping Inactive", 48)
liveFillLabel = buildMetric("Cargo Matrix Load: 📦 Load: N/A", 70)
liveCyclesLabel = buildMetric("Batch Sequence loops: 📊 Cycles: 0/0", 92)

-- Global keybind toggle handler
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == UI_KEYBIND then
        mainWindow.Visible = not mainWindow.Visible
    end
end)

-- Background Telemetry Refresh Daemon Thread
task.spawn(function()
    while true do
        refreshAnalyticsDisplay()
        task.wait(0.5)
    end
end)
